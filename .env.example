# Scegli uno o entrambi i provider AI (opzionali)
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# AI cascade thresholds (0.0 - 1.0)
OLLAMA_CONFIDENCE_THRESHOLD=0.75
HAIKU_CONFIDENCE_THRESHOLD=0.80

# Max cloud escalations per run (cost control)
MAX_CLOUD_ESCALATIONS=200

# Model overrides (opzionali)
HAIKU_MODEL=claude-haiku-4-5
OPUS_MODEL=claude-opus-4-8
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# Paths
CREDENTIALS_PATH=credentials.json
TOKENS_DIR=tokens
ROLLBACK_DIR=logs
